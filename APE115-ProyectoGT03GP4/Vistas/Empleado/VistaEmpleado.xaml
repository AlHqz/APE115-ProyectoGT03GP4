<Window x:Class="APE115_ProyectoGT03GP4.VistaEmpleado"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:APE115_ProyectoGT03GP4"
        mc:Ignorable="d"
        Title="VistaEmpleado" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!--Menú de opciones universal-->
        <Menu Grid.Row="0" VerticalAlignment="Top" HorizontalAlignment="Stretch" Padding="5">
            <MenuItem Header="Stock" Command="{x:Static local:VistaEmpleado.NavegarStockCmd}" InputGestureText="Ctrl+Q" ToolTip="Visualizar Stock (Ctrl+Q)"/>
            <MenuItem Header="Informe" Margin="15, 0, 0, 0" Command="{x:Static local:VistaEmpleado.NavegarInformeCmd}" InputGestureText="Ctrl+I" ToolTip="Informe (Ctrl+I)"/>
        </Menu>
        <!---Resto del contenido en la pantalla-->
        <Frame x:Name="AreaContenido" 
               Grid.Row="1" 
               Source="/Vistas/Stock.xaml" 
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
