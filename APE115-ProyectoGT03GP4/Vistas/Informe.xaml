<Page x:Class="APE115_ProyectoGT03GP4.Vistas.Informe"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:APE115_ProyectoGT03GP4.Vistas"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Informe">

    <Grid Background="#F4F7F9">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="20,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⚠️" FontSize="30" Margin="0,0,15,0" VerticalAlignment="Center"/>
                <StackPanel>
                    <TextBlock Text="INFORME DE REABASTECIMIENTO CRÍTICO" Foreground="White" FontSize="18" FontWeight="Bold"/>
                    <TextBlock Text="Productos cuyo stock es igual o inferior al mínimo establecido" Foreground="#BDC3C7" FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" Margin="15,10" CornerRadius="5" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Filtrar Informe por Categoría:" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,10,0"/>
                <ComboBox x:Name="CmbCategoriaInforme" Width="200" Height="30" 
                          DisplayMemberPath="Nombre" SelectedValuePath="IdCategoria"
                          SelectionChanged="CmbCategoriaInforme_SelectionChanged"/>

                <Button x:Name="BtnLimpiarFiltro" Content="Ver Todo el Bajo Stock" Margin="15,0,0,0" Padding="10,0" Click="BtnLimpiarFiltro_Click"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="GridInformeBajoStock" Grid.Row="2" Margin="15,5" 
                  AutoGenerateColumns="False" IsReadOnly="True" 
                  Background="White" BorderBrush="#D1D8E0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Cod." Binding="{Binding IdProducto}" Width="60"/>
                <DataGridTextColumn Header="Descripción del Producto" Binding="{Binding Descripcion}" Width="*"/>

                <DataGridTemplateColumn Header="Estado Crítico" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Background="#FADBD8" CornerRadius="10" Padding="5,2">
                                <TextBlock Text="BAJO STOCK" Foreground="#C0392B" FontWeight="Bold" HorizontalAlignment="Center" FontSize="10"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Stock Actual" Binding="{Binding Stock}" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Stock Mínimo" Binding="{Binding StockMinimo}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3" Background="#ECF0F1" Padding="20,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Total de productos en alerta:" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtTotalAlertas" Text="0" Margin="10,0,0,0" FontSize="16" FontWeight="Bold" Foreground="#C0392B" VerticalAlignment="Center"/>
                </StackPanel>

                <Button x:Name="BtnImprimir" Content="🖨️ Generar PDF / Imprimir" 
                        HorizontalAlignment="Right" Padding="15,8" 
                        Background="#3498DB" Foreground="White" FontWeight="Bold" Click="BtnImprimir_Click"/>
            </Grid>
        </Border>
    </Grid>
</Page>
