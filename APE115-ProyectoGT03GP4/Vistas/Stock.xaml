<Page x:Class="APE115_ProyectoGT03GP4.Vistas.Stock"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:APE115_ProyectoGT03GP4.Vistas"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Stock">

    <Grid>
        <StackPanel Margin="20">
            <DockPanel Margin="10">
                <TextBlock Text="Stock Actual" FontSize="20" FontWeight="Bold" Margin="0,0,20,0"/>
                <TextBlock Text="Filtrar por categoría: " FontSize="12"/>
            </DockPanel>
            <DataGrid x:Name="StockDataGrid" AutoGenerateColumns="False" Margin="10">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID Producto" Binding="{Binding IdProducto}" Width="*"/>
                    <DataGridTextColumn Header="Nombre" Binding="{Binding Nombre}" Width="*"/>
                    <DataGridTextColumn Header="Cantidad" Binding="{Binding Cantidad}" Width="*"/>
                    <DataGridTextColumn Header="Precio Unitario" Binding="{Binding PrecioUnitario}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
    </Grid>
</Page>
