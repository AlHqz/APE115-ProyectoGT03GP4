<Page x:Class="APE115_ProyectoGT03GP4.Vistas.Stock"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:APE115_ProyectoGT03GP4.Vistas"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Stock">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="10,0,10,15" LastChildFill="False">
            <TextBlock Text="Stock Actual" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Filtrar por categoría: " FontSize="13" VerticalAlignment="Center" Margin="50,0,15,0"/>
                <ComboBox x:Name="CmbCategoria" Width="180" Height="28" VerticalContentAlignment="Center"
                          DisplayMemberPath="Nombre" SelectedValuePath="IdCategoria" SelectionChanged="CmbCategoria_SelectionChanged"/>
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="DtgProductos" Grid.Row="1" AutoGenerateColumns="False" Margin="10" 
                  AlternatingRowBackground="#F9F9F9" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID Producto" Binding="{Binding IdProducto}" Width="80"/>
                <DataGridTextColumn Header="Descripción / Nombre" Binding="{Binding Descripcion}" Width="*"/>
                <DataGridTextColumn Header="Cantidad disponible" Binding="{Binding Stock}" Width="150"/>
                <DataGridTextColumn Header="Precio Unitario" Binding="{Binding Precio, StringFormat={}{0:C}}" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
        <!--Botones para modificar stock-->

        <UniformGrid Grid.Row="3" Columns="3" Margin="10,15,10,10" Height="45">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Cantidad: " FontSize="13" VerticalAlignment="Center" Margin="50,0,15,0"/>
                <TextBox x:Name="TxtCantidad" Width="100"/>
            </StackPanel>
            <Button x:Name="BtnAgregar" Content="➕ Agregar Stock" FontSize="14" FontWeight="SemiBold" 
                    Background="#2ECC71" Foreground="White" Margin="0,0,10,0" Click="AgregarStock"/>
            <Button x:Name="BtnRetirar" Content="➖ Retirar Stock" FontSize="14" FontWeight="SemiBold" 
                    Background="#E74C3C" Foreground="White" Margin="10,0,0,0" Click="RetirarStock"/>
        </UniformGrid>
    </Grid>
</Page>