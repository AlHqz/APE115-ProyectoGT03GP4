<Page x:Class="APE115_ProyectoGT03GP4.Vistas.Admin.AgregarProducto"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:APE115_ProyectoGT03GP4.Vistas.Admin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AgregarProducto">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="📦 Registro de Nuevo Producto" FontSize="22" FontWeight="Bold" Foreground="#2C3E50"/>
            <Separator Margin="0,10,0,0" Background="#BDC3C7"/>
        </StackPanel>

        <GroupBox Header=" Datos del Artículo " Grid.Row="1" Padding="20" FontSize="13">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,20,15">
                    <TextBlock Text="Descripción / Nombre:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <TextBox x:Name="TxtDescripcion" Height="28" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,20,15">
                    <TextBlock Text="Categoría:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                    <ComboBox x:Name="CmbCategoria" Height="28" VerticalContentAlignment="Center"
                              DisplayMemberPath="Nombre" SelectedValuePath="IdCategoria"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Costo ($):" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox x:Name="TxtCosto" Height="28" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Precio Venta ($):" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox x:Name="TxtPrecio" Height="28" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,15">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Stock Inicial:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox x:Name="TxtStock" Height="28" VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Stock Mínimo:" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <TextBox x:Name="TxtStockMinimo" Height="28" VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="BtnGuardar" Content="💾 Guardar Producto" Width="180" Height="35" 
                    FontWeight="Bold" Background="#3498DB" Foreground="White" Click="BtnGuardar_Click"/>
        </StackPanel>
    </Grid>
</Page>
