<Page x:Class="APE115_ProyectoGT03GP4.Vistas.Admin.EliminarCategoria"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:APE115_ProyectoGT03GP4.Vistas.Admin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EliminarCategoria">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Eliminar Categorías" FontSize="20" FontWeight="Bold"/>
            <TextBlock Text="Seleccione la categoría que desea remover del sistema." FontSize="12" Foreground="Gray"/>
        </StackPanel>

        <DataGrid x:Name="DtgCategorias" Grid.Row="1" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True"
                  SelectionMode="Single"
                  AlternatingRowBackground="#F2F2F2"
                  HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding IdCategoria}" Width="100"/>
                <DataGridTextColumn Header="Nombre de la Categoría" Binding="{Binding Nombre}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <TextBlock Text="⚠️ Esta acción no se puede deshacer" VerticalAlignment="Center" Margin="0,0,20,0" Foreground="#C0392B" FontStyle="Italic"/>
            <Button x:Name="BtnBorrar" 
                    Content="🗑️ Eliminar Seleccionada" 
                    Width="180" Height="35" 
                    FontSize="13" FontWeight="Bold"
                    Background="#E74C3C" Foreground="White"
                    Click="BtnBorrar_Click"/>
        </StackPanel>
    </Grid>
</Page>
