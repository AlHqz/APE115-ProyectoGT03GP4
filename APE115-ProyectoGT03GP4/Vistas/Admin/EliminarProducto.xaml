<Page x:Class="APE115_ProyectoGT03GP4.Vistas.Admin.EliminarProducto"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:APE115_ProyectoGT03GP4.Vistas.Admin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EliminarProducto">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="5,0,5,10" LastChildFill="False">
            <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                <TextBlock Text="Dar de Baja Productos" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="Busque y seleccione el artículo que será removido permanentemente." FontSize="12" Foreground="Gray"/>
            </StackPanel>

            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Producto: " FontSize="13" VerticalAlignment="Center" Margin="20,0,5,0"/>
                <TextBox x:Name="TxtProducto" Width="150" Height="25" VerticalContentAlignment="Center"/>
                <Button x:Name="BtnBuscar" Content="Buscar" Width="75" Height="25" Margin="10,0,0,0" FontWeight="Bold" Click="BuscarProducto"/>
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="DtgProductos" Grid.Row="1" AutoGenerateColumns="False" Margin="5" 
                  IsReadOnly="True" SelectionMode="Single"
                  AlternatingRowBackground="#F2F2F2" GridLinesVisibility="Horizontal" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID Producto" Binding="{Binding IdProducto}" Width="80"/>
                <DataGridTextColumn Header="Descripción / Nombre" Binding="{Binding Descripcion}" Width="*"/>
                <DataGridTextColumn Header="Stock Act." Binding="{Binding Stock}" Width="100"/>
                <DataGridTextColumn Header="Precio" Binding="{Binding Precio, StringFormat={}{0:C}}" Width="110"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2" Margin="5,15,5,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="⚠️ Alerta:" FontWeight="Bold" Foreground="#C0392B" VerticalAlignment="Center" Margin="5,0,5,0"/>
                <TextBlock Text="Eliminar un artículo afectará los históricos y reportes de stock actuales." Foreground="#555555" VerticalAlignment="Center" FontStyle="Italic"/>
            </StackPanel>

            <Button x:Name="BtnEliminar" Grid.Column="1" 
                    Content="🗑️ Eliminar Producto" 
                    Width="180" Height="35" 
                    FontSize="13" FontWeight="Bold"
                    Background="#E74C3C" Foreground="White" 
                    Click="BtnEliminar_Click"/>
        </Grid>
    </Grid>
</Page>
