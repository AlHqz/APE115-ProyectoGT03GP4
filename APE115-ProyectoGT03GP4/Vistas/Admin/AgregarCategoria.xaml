<Page x:Class="APE115_ProyectoGT03GP4.Vistas.Admin.AgregarCategoria"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:APE115_ProyectoGT03GP4.Vistas.Admin"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AgregarCategoria">

    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">

        <GroupBox Header=" Registro de Nueva Categoría " FontSize="14" FontWeight="Bold" Padding="20" Width="400">
            <StackPanel Margin="10">

                <TextBlock Text="Ingrese el nombre de la nueva categoría de ferretería:" 
                           FontSize="12" FontWeight="Normal" Foreground="#333333" Margin="0,0,0,10" TextWrapping="Wrap"/>

                <TextBox x:Name="TxtNombreCategoria" 
                         Height="30" 
                         FontSize="13" 
                         FontWeight="Normal"
                         VerticalContentAlignment="Center" 
                         Padding="5,0"
                         Margin="0,0,0,20"/>

                <Button x:Name="BtnGuardarCategoria" 
                        Content="💾 Guardar Categoría" 
                        Height="35" 
                        FontSize="13" 
                        FontWeight="Bold" 
                        Background="#2ECC71" 
                        Foreground="White" 
                        Click="BtnGuardarCategoria_Click"/>

            </StackPanel>
        </GroupBox>

    </Grid>
</Page>
