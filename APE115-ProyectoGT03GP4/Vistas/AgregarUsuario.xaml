<Window x:Class="APE115_ProyectoGT03GP4.Vistas.AgregarUsuario"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:APE115_ProyectoGT03GP4.Vistas"
        mc:Ignorable="d"
        Title="AgregarUsuario" Height="530" Width="800" Loaded="Window_Loaded">
    <Grid Margin="10,10,10,98">
        <Viewbox Margin="0,27,0,111"/>

        <GroupBox HorizontalAlignment="Center" Height="389" Header="Informacion de Usuario" Margin="0,27,0,0" VerticalAlignment="Top" Width="736">
            <Grid Height="361" Margin="2,0,-2,0">
                <Label Content="Nombre de Usuario" HorizontalAlignment="Left" Margin="22,10,0,0" VerticalAlignment="Top" FontSize="14"/>
                <TextBox x:Name="txtusuario" HorizontalAlignment="Left" Margin="28,44,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="672" FontSize="14" Height="40" RenderTransformOrigin="0.5,0.5">
                    <TextBox.RenderTransform>
                        <TransformGroup>
                            <ScaleTransform/>
                            <SkewTransform/>
                            <RotateTransform Angle="-0.038"/>
                            <TranslateTransform/>
                        </TransformGroup>
                    </TextBox.RenderTransform>
                </TextBox>
                <Label Content="Contraseña" HorizontalAlignment="Left" Margin="28,91,0,0" VerticalAlignment="Top" FontSize="14"/>
                <PasswordBox x:Name="txtContra" HorizontalAlignment="Center" VerticalAlignment="Top" Width="668" Height="40" Margin="0,124,0,0"/>
                <Label Content="Repetir Contraseña" HorizontalAlignment="Left" Margin="28,178,0,0" VerticalAlignment="Top" FontSize="14"/>
                <PasswordBox x:Name="txtContraR" HorizontalAlignment="Center" VerticalAlignment="Top" Width="668" Height="40" Margin="0,211,0,0"/>
                <Label Content="Tipo de Usuario" HorizontalAlignment="Left" Margin="28,264,0,0" VerticalAlignment="Top" FontSize="14"/>
                <ComboBox x:Name="cbTipoUsuario" HorizontalAlignment="Center" Margin="0,298,0,0" VerticalAlignment="Top" Width="668" Height="41"/>
            </Grid>
        </GroupBox>
        <StackPanel Margin="0,27,0,5"/>
        <Grid Margin="0,416,22,-95">
            <Button Content="Registrarse" HorizontalAlignment="Left" Margin="33,0,0,0" VerticalAlignment="Center" Width="231" Height="47" FontSize="14" Foreground="White" FontWeight="Bold" Background="#FF0B41D1" Click="Button_Click"/>
        </Grid>

    </Grid>
</Window>
